# ============================================================
# WinForge - .gitignore
# ============================================================

# ----- Runtime artefacts -----
# Logs generated by the installer at runtime
*.log
WinForge_install_log.txt
BoschiInizializer_install_log.txt

# Staging folder used by the installer (auto-cleaned on exit)
/WinForge_tmp/

# Temp binaries downloaded during driver/app installation
*.tmp
TeamViewer_Setup*.exe
Dell-Command-Update*.EXE
SupportAssistInstaller*.exe
windowsdesktop-runtime-*.exe
Microsoft365Setup*.exe

# ----- Inventory exports (future: if WinForge ever dumps device data) -----
inventory_*.txt
inventory_*.json
inventory_*.csv
*-inventory.*
devices_*.json
device_dump_*.*

# ----- Credentials / secrets -----
# Environment variable files
.env
.env.*
*.env

# Generic secret / credential files
secrets.*
credentials.*
*.secret
*.secrets
auth.json
token.json
api-keys.*

# Certificates and private keys
*.pem
*.key
*.crt
*.cer
*.pfx
*.p12
*.jks

# SSH keys
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.ppk

# PowerShell credential exports (Export-Clixml of PSCredential)
*.clixml
*SecureString*
*Credential*.xml
PSReadLine*.txt

# Local config overrides
local.config
local.settings.json
*.local.ps1
*.local.json
*.local.config

# ----- Personal / draft / WIP files -----
NOTES.md
TODO.md
SCRATCH.md
TODO.txt
NOTES.txt
draft/
drafts/
scratch/
wip/
private/
personal/

# ----- Backup files -----
*.bak
*.backup
*.orig
*.old
*~

# ----- Editor / IDE metadata -----
.vscode/
.idea/
*.swp
*.swo
*.suo
.vs/

# ----- OS metadata -----
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
ehthumbs_vista.db
desktop.ini
$RECYCLE.BIN/

# ----- PowerShell -----
*.ps1.bak
*.psd1.bak
*.psm1.bak
PSScriptAnalyzerSettings.psd1.local

# ----- Screenshot drafts (not for publishing) -----
screenshots/_drafts/
screenshots/wip/
*.tmp.png
*~.png
